# ============================================================
# Feature Flag SaaS — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# JWT — use a long, random string in production
JWT_SECRET=replace_this_with_a_long_random_secret_at_least_32_chars

# Super Admin (static credentials — keep private)
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=superpassword

# SQLite database file path (relative to backend directory)
DB_PATH=./data/feature_flags.db
